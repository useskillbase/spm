{
  "name": "@skillbase/spm",
  "version": "0.4.0",
  "description": "AI skills manager — install, publish, and deploy reusable prompts, personas, and MCP tools across 14 AI clients",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/useskillbase/spm.git"
  },
  "bugs": {
    "url": "https://github.com/useskillbase/spm/issues"
  },
  "keywords": [
    "ai",
    "skills",
    "package-manager",
    "mcp",
    "mcp-server",
    "model-context-protocol",
    "prompts",
    "prompt-engineering",
    "prompt-management",
    "personas",
    "ai-tools",
    "ai-agents",
    "llm",
    "cli",
    "claude",
    "cursor",
    "vscode",
    "copilot",
    "windsurf",
    "zed",
    "cline",
    "jetbrains",
    "gemini",
    "ai-workflow"
  ],
  "author": "Skillbase <contact@skillbase.space>",
  "homepage": "https://skillbase.space",
  "license": "MIT",
  "files": [
    "dist",
    "LICENSE",
    "README.md",
    "CHANGELOG.md"
  ],
  "bin": {
    "spm": "./dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "reindex": "node --loader ts-node/esm src/scripts/reindex.ts",
    "start": "node dist/cli/index.js",
    "spm": "node dist/cli/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "version": "bash scripts/release-changelog.sh",
    "prepublishOnly": "npm run build && npm test"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1007.0",
    "@aws-sdk/s3-request-presigner": "^3.1007.0",
    "@clack/prompts": "^1.1.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@octokit/rest": "^22.0.1",
    "ajv": "^8.18.0",
    "commander": "^14.0.3",
    "jsonc-parser": "^3.3.1",
    "picocolors": "^1.1.1",
    "semver": "^7.7.4",
    "tar-stream": "^3.1.8"
  },
  "devDependencies": {
    "@types/node": "^25.4.0",
    "@types/semver": "^7.7.1",
    "@types/tar-stream": "^3.1.4",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
